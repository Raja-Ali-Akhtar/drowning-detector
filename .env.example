# ============================================================
# Drowning Detection System — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ── App ──────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/drowning_db

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Twilio (SMS Alerts) ─────────────────────────────────
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1234567890
ALERT_PHONE_NUMBERS=+1234567890,+0987654321

# ── AWS ──────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=drowning-detector-incidents

# ── Model Paths ──────────────────────────────────────────
YOLO_WEIGHTS_PATH=models/detector/yolov8_pool.pt
MODEL_WEIGHTS_PATH=models/classifier/best.pt

# ── Detection ────────────────────────────────────────────
ALERT_CONFIDENCE_THRESHOLD=0.75

# ── Monitoring ───────────────────────────────────────────
SENTRY_DSN=
ENABLE_PROMETHEUS=true
